  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Abrir painel de controle",
      "url": "/?view=dashboard&source=shortcut",
      "icons": [{ "src": "/icons/shortcut-dashboard.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "PDV",
      "short_name": "PDV",
      "description": "Abrir ponto de venda",
      "url": "/?view=pdv&source=shortcut",
      "icons": [{ "src": "/icons/shortcut-pdv.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Estoque",
      "short_name": "Estoque",
      "description": "Gerenciar estoque",
      "url": "/?view=estoque&source=shortcut",
      "icons": [{ "src": "/icons/shortcut-estoque.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Relatórios",
      "short_name": "Relatórios",
